// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "format_on_save": "on",
  "formatter": "language_server",
  "languages": {
    "TypeScript": {
      "formatter": {
        "language_server": {
          "name": "oxfmt"
        }
      }
    },
    "TSX": {
      "formatter": {
        "language_server": {
          "name": "oxfmt"
        }
      }
    },
    "JavaScript": {
      "formatter": {
        "language_server": {
          "name": "oxfmt"
        }
      }
    },
    "Astro": {
      "formatter": {
        "language_server": {
          "name": "oxfmt"
        }
      }
    }
  }, // languages
  "outline_panel": {
    "dock": "right"
  },
  "buffer_line_height": "comfortable",
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "title_bar": {
    "show_menus": true
  },
  "terminal": {
    "copy_on_select": true,
    "font_size": 15.0,
    "font_family": "FiraCode Nerd Font Mono",
    "shell": "system"
  },
  "git_panel": {
    "dock": "right",
    "tree_view": true,
    "status_style": "label_color"
  },
  "tabs": {
    "show_diagnostics": "errors",
    "close_position": "left",
    "file_icons": false
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry"
    },
    "claude-acp": {
      "favorite_config_option_values": {
        "model": ["default"]
      },
      "type": "registry"
    },
    "opencode": {
      "type": "registry"
    }
  },
  "icon_theme": "Catppuccin Macchiato",
  "project_panel": {
    "git_status": false,
    "dock": "right"
  },
  "buffer_font_features": {
    "calt": false // Disable ligatures
  },
  "agent": {
    "inline_assistant_model": {
      "provider": "anthropic",
      "model": "claude-opus-4-7-latest",
      "enable_thinking": false
    },
    "dock": "left",
    "default_model": {
      "effort": "high",
      "provider": "copilot_chat",
      "model": "gpt-5-mini"
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "ui_font_size": 16,
  "buffer_font_size": 14.5,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "macOS Classic Dark"
  },
  // Disable the buttons I do not use.
  "collaboration_panel": {
    "dock": "right",
    "button": false
  },
  "context_servers": {
    "posthog": {
      "enabled": true,
      "url": "https://mcp.posthog.com/mcp?features=experiments,surveys,annotations,sql,llm_analytics,prompts,flags,cohorts,data_warehouse,data_schema,hog_functions,hog_function_templates,workflows,workspace,docs,notebooks,alerts,activity_logs,search,reverse_proxy,debug",
      "headers": {
        "Authorization": "Bearer undefined"
      }
    }
  }
}
