// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "edit_predictions": {
    "provider": "zed"
  },
  "cli_default_open_behavior": "new_window",
  "format_on_save": "on",
  "formatter": "language_server",
  "languages": {
    "TypeScript": {
      "formatter": {
        "language_server": {
          "name": "oxfmt"
        }
      }
    },
    "TSX": {
      "formatter": {
        "language_server": {
          "name": "oxfmt"
        }
      }
    },
    "JavaScript": {
      "formatter": {
        "language_server": {
          "name": "oxfmt"
        }
      }
    },
    "Astro": {
      "formatter": {
        "language_server": {
          "name": "oxfmt"
        }
      }
    }
  }, // languages
  "outline_panel": {
    "dock": "right"
  },
  "buffer_line_height": "comfortable",
  "buffer_font_family": "FiraMono Nerd Font Mono",
  "title_bar": {
    "show_menus": true
  },
  "terminal": {
    "dock": "bottom",
    "copy_on_select": true,
    "font_size": 15.0,
    "font_family": "FiraCode Nerd Font Mono",
    "shell": "system"
  },
  "git_panel": {
    "dock": "right",
    "tree_view": true,
    "status_style": "label_color"
  },
  "tabs": {
    "show_diagnostics": "errors",
    "close_position": "left",
    "file_icons": false
  },
  "agent_servers": {
    "opencode": {
      "default_config_options": {
        "model": "opencode-go/kimi-k3",
        "mode": "plan"
      },
      "type": "registry"
    },
    "codex-acp": {
      "default_config_options": {
        "collaboration_mode": "plan",
        "fast-mode": false
      },
      "type": "registry"
    },
    "claude-acp": {
      "default_config_options": {
        "model": "claude-fable-5[1m]",
        "mode": "plan"
      },
      "favorite_config_option_values": {
        "model": ["default"]
      },
      "type": "registry"
    }
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Macchiato",
    "dark": "Material Icon Theme"
  },
  "project_panel": {
    "git_status": false,
    "dock": "right"
  },
  "buffer_font_features": {
    "calt": false // Disable ligatures
  },
  "agent": {
    "auto_compact": {
      "threshold": "90%"
    },
    "play_sound_when_agent_done": "never",
    "notify_when_agent_waiting": "never",
    "dock": "left",
    "default_model": {
      "effort": "high",
      "provider": "zed.dev",
      "model": "gpt-5.5-pro"
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "ui_font_size": 16,
  "buffer_font_size": 14.5,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Ayu Dark"
  },
  // Disable the buttons I do not use.
  "collaboration_panel": {
    "dock": "right",
    "button": false
  },
  "context_servers": {
    "posthog": {
      "enabled": true,
      "url": "https://mcp.posthog.com/mcp?features=experiments,surveys,annotations,sql,llm_analytics,prompts,flags,cohorts,data_warehouse,data_schema,hog_functions,hog_function_templates,workflows,workspace,docs,notebooks,alerts,activity_logs,search,reverse_proxy,debug",
      "headers": {
        "Authorization": "Bearer undefined"
      }
    }
  }
}
